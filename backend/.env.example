LILA_ALLOWED_ORIGINS=http://localhost:8080
LILA_WHISPER_MODEL=tiny.en
LILA_WHISPER_DEVICE=cpu
LILA_WHISPER_COMPUTE_TYPE=int8
LILA_DEFAULT_SPEAKER_COUNT=5
LILA_MAX_SPEAKER_COUNT=5
LILA_MAX_AUDIO_BYTES=83886080

# Required for persistence from the backend.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local-only testing with http://127.0.0.1 audio URLs.
# LILA_ALLOW_LOCAL_AUDIO_URLS=true
